modules = ["java-graalvm22.3"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build Mod"

[[workflows.workflow]]
name = "Build Mod"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "export JAVA_HOME=/nix/store/3ilfkn8kxd9f6g5hgr0wpbnhghs4mq2m-openjdk-21.0.7+6 && export PATH=$JAVA_HOME/bin:$PATH && ./gradlew build --no-daemon -x test -x checkstyleMain -x spotlessCheck 2>&1"

[workflows.workflow.metadata]
outputType = "console"
